      <column caption='Coverage Status' datatype='string' name='[Calculation_0195441983664128]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2303755190366210] &gt; 1000 THEN &quot;Critical&quot;&#13;&#10;ELSEIF [Calculation_2303755190366210] &gt; 500 THEN &quot;Moderate&quot;&#13;&#10;ELSE &quot;Healthy&quot;&#13;&#10;END' />
      </column>
      <column caption='Total EV Count' datatype='integer' name='[Calculation_0283136489463808]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[2W] + [3W] + [4W] + [OTHERS]' />
      </column>
      <column caption='CHARGING DENSITY INDEX' datatype='real' name='[Calculation_0945034191527936]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([CHARGING_STATIONS]) = 0 THEN 0&#13;&#10;ELSE&#13;&#10;SUM([EV_COUNT]) / SUM([CHARGING_STATIONS])&#13;&#10;END' />
      </column>
      <column caption='CDI Status' datatype='string' name='[Calculation_0945034191982593]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0945034191527936] &gt; 120 THEN &quot;Critical&quot;&#13;&#10;&#13;&#10;ELSEIF [Calculation_0945034191527936] &gt; 50 THEN &quot;Moderate&quot;&#13;&#10;&#13;&#10;ELSE &quot;Healthy&quot;&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='STATES COUNT' datatype='integer' name='[Calculation_1282681471851462656]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([State])' />
      </column>
      <column caption='EV PER CHARGER  RATIO' datatype='real' name='[Calculation_1282681471875309569]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([EV_COUNT])/ SUM([CHARGING_STATIONS])' />
      </column>
      <column caption='FAST_CHARGERS' datatype='integer' name='[Calculation_1282681471900385282]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([FAST CHARGER])' />
      </column>
      <column caption='SLOW_CHARGERS' datatype='integer' name='[Calculation_1282681471900549123]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([SLOW CHARGER])' />
      </column>
      <column caption='One' datatype='integer' name='[Calculation_1282681471912214532]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
      <column caption='2W Deficit' datatype='real' name='[Calculation_1512666050748417]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [CHARGING_STATIONS] &gt; 0 THEN&#13;&#10;[2W]/[CHARGING_STATIONS]&#13;&#10;END' />
      </column>
      <column caption='3W Deficit' datatype='real' name='[Calculation_1512666050834434]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [CHARGING_STATIONS] &gt; 0 THEN&#13;&#10;[3W]/[CHARGING_STATIONS]&#13;&#10;END' />
      </column>
      <column caption='4W Deficit' datatype='real' name='[Calculation_1512666050895875]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [CHARGING_STATIONS] &gt; 0 THEN&#13;&#10;[4W]/[CHARGING_STATIONS]&#13;&#10;END' />
      </column>
      <column caption='EV Growth %' datatype='real' name='[Calculation_1512666053009412]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;SUM([EV_COUNT])&#13;&#10;-&#13;&#10;LOOKUP(SUM([EV_COUNT]),-1)&#13;&#10;)&#13;&#10;/&#13;&#10;ABS(LOOKUP(SUM([EV_COUNT]),-1))&#13;&#10;*100'>
          <table-calc ordering-field='[federated.13gvhhg19wd4i118qc4a7122l8m8].[Year]' ordering-type='Field' />
        </calculation>
      </column>
      <column caption='Charger Growth %' datatype='real' name='[Calculation_1512666053152773]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;SUM([CHARGING_STATIONS])&#13;&#10;-&#13;&#10;LOOKUP(SUM([CHARGING_STATIONS]),-1)&#13;&#10;)&#13;&#10;/&#13;&#10;ABS(LOOKUP(SUM([CHARGING_STATIONS]),-1))&#13;&#10;*100'>
          <table-calc ordering-field='[federated.13gvhhg19wd4i118qc4a7122l8m8].[Year]' ordering-type='Field' />
        </calculation>
      </column>
      <column caption='EV CAGR' datatype='real' default-format='p0.0%' name='[Calculation_1512666057691143]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;SUM(&#13;&#10;IF [Year]=2026 THEN [EV_COUNT] END&#13;&#10;)&#13;&#10;/&#13;&#10;SUM(&#13;&#10;IF [Year]=2023 THEN [EV_COUNT] END&#13;&#10;)&#13;&#10;)^(1/3)-1' />
      </column>
      <column caption='Charger CAGR' datatype='real' default-format='p0.0%' name='[Calculation_1512666057846792]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;SUM(&#13;&#10;IF [Year]=2026 THEN [CHARGING_STATIONS] END&#13;&#10;)&#13;&#10;/&#13;&#10;SUM(&#13;&#10;IF [Year]=2023 THEN [CHARGING_STATIONS] END&#13;&#10;)&#13;&#10;)^(1/3)-1' />
      </column>
      <column caption='Growth Divergence' datatype='real' name='[Calculation_1512666058416137]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1512666057691143] - [Calculation_1512666057846792]' />
      </column>
      <column caption='Negative Charger CAGR' datatype='real' name='[Calculation_1512666058665994]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='-[Calculation_1512666057846792]' />
      </column>
      <column caption='Risk Category' datatype='string' name='[Calculation_1512666061090827]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1512666058416137] &gt; 0.15 THEN &quot;Critical&quot;&#13;&#10;ELSEIF [Calculation_1512666058416137] &gt; 0.05 THEN &quot;Warning&quot;&#13;&#10;ELSE &quot;Balanced&quot;&#13;&#10;END' />
      </column>
      <column caption='Fast Charger Readiness %' datatype='real' name='[Calculation_1695460184875011]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([FAST CHARGER]) / SUM([CHARGING_STATIONS])' />
      </column>
      <column caption='Charging Density' datatype='real' name='[Calculation_2303755156340736]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([CHARGING_STATIONS]) / SUM([EV_COUNT])) * 1000000' />
      </column>
      <column caption='CDI' datatype='real' name='[Calculation_2303755190366210]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;SUM([FAST CHARGER]) + SUM([SLOW CHARGER])&#13;&#10;)&#13;&#10;/&#13;&#10;SUM([EV_COUNT])&#13;&#10;* 1000000' />
      </column>
      <column caption='2W Simulated Strain' datatype='real' name='[Calculation_2636642118512640]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([2W]) / (SUM([CHARGING_STATIONS]) + [Parameters].[EV PER CHARGER  RATIO Parameter])' />
      </column>
      <column caption='4W Simulated Strain' datatype='real' name='[Calculation_2636642118660097]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([4W]) / (SUM([CHARGING_STATIONS]) + [Parameters].[EV PER CHARGER  RATIO Parameter])' />
      </column>
      <column caption='3W Simulated Strain' datatype='real' name='[Calculation_2636642118864898]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([3W]) / (SUM([CHARGING_STATIONS]) + [Parameters].[EV PER CHARGER  RATIO Parameter])' />
      </column>
