          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Tableau Semibold'>SEGEMENT STRAIN MATRIX : EV Infrastructure Deficit by Vehicle Type (2018–2026)</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='EV_DASHBOARD (EV_DASHBOARD.csv)' name='federated.13gvhhg19wd4i118qc4a7122l8m8' />
          </datasources>
          <datasource-dependencies datasource='federated.13gvhhg19wd4i118qc4a7122l8m8'>
            <column datatype='integer' name='[2W]' role='measure' type='quantitative' />
            <column datatype='integer' name='[3W]' role='measure' type='quantitative' />
            <column datatype='integer' name='[4W]' role='measure' type='quantitative' />
            <column caption='Charging Stations' datatype='integer' name='[CHARGING_STATIONS]' role='measure' type='quantitative' />
            <column caption='2W Deficit' datatype='real' name='[Calculation_1512666050748417]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [CHARGING_STATIONS] &gt; 0 THEN&#13;&#10;[2W]/[CHARGING_STATIONS]&#13;&#10;END' />
            </column>
            <column caption='3W Deficit' datatype='real' name='[Calculation_1512666050834434]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [CHARGING_STATIONS] &gt; 0 THEN&#13;&#10;[3W]/[CHARGING_STATIONS]&#13;&#10;END' />
            </column>
            <column caption='4W Deficit' datatype='real' name='[Calculation_1512666050895875]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [CHARGING_STATIONS] &gt; 0 THEN&#13;&#10;[4W]/[CHARGING_STATIONS]&#13;&#10;END' />
            </column>
            <column caption='CDI' datatype='real' name='[Calculation_2303755190366210]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(&#13;&#10;SUM([FAST CHARGER]) + SUM([SLOW CHARGER])&#13;&#10;)&#13;&#10;/&#13;&#10;SUM([EV_COUNT])&#13;&#10;* 1000000' />
            </column>
            <column caption='Ev Count' datatype='integer' name='[EV_COUNT]' role='measure' type='quantitative' />
            <column caption='Fast Charger' datatype='integer' name='[FAST CHARGER]' role='measure' type='quantitative' />
            <column caption='Slow Charger' datatype='integer' name='[SLOW CHARGER]' role='measure' type='quantitative' />
            <column datatype='string' name='[State]' role='dimension' semantic-role='[State].[Name]' type='nominal'>
